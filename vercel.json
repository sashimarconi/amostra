{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "/assets/logo-tiktok-CfBkyC_V_\\(1\\)_1771528904425-Cypgxkyq\\.png",
      "dest": "/irpf-soluciona.org/assets/logo-tiktok-shop.svg"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/irpf-soluciona.org/assets/$1"
    },
    {
      "src": "/irpf-soluciona.org/informativo.html",
      "status": 308,
      "headers": {
        "Location": "/informativo"
      }
    },
    {
      "src": "/irpf-soluciona.org/index.html",
      "status": 308,
      "headers": {
        "Location": "/"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/irpf-soluciona.org/index.html"
    },
    {
      "src": "/informativo",
      "dest": "/irpf-soluciona.org/index.html"
    },
    {
      "src": "/checkout",
      "dest": "/irpf-soluciona.org/index.html"
    },
    {
      "src": "/pagamento",
      "dest": "/irpf-soluciona.org/index.html"
    },
    {
      "src": "/product/(.*)",
      "dest": "/irpf-soluciona.org/index.html"
    }
  ]
}
