{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "/irpf-soluciona.org/informativo.html",
      "status": 308,
      "headers": {
        "Location": "/informativo"
      }
    },
    {
      "src": "/irpf-soluciona.org/index.html",
      "status": 308,
      "headers": {
        "Location": "/"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/irpf-soluciona.org/index.html"
    },
    {
      "src": "/informativo",
      "dest": "/irpf-soluciona.org/index.html"
    },
    {
      "src": "/checkout",
      "dest": "/irpf-soluciona.org/index.html"
    },
    {
      "src": "/pagamento",
      "dest": "/irpf-soluciona.org/index.html"
    },
    {
      "src": "/product/(.*)",
      "dest": "/irpf-soluciona.org/index.html"
    }
  ]
}
